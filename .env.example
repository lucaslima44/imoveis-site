# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local — ele já está no .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT — Segredo para assinar os tokens de sessão do admin ──────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=troque_por_uma_string_aleatoria_muito_longa_aqui

# ── Credenciais do administrador ─────────────────────────────────────────────
ADMIN_USERNAME=admin

# Hash bcrypt da senha (custo 12). Para gerar:
#   npm run hash-password -- SuaSenhaAqui
ADMIN_PASSWORD_HASH=$2b$12$troque_pelo_hash_bcrypt_gerado_acima

# ── Supabase ─────────────────────────────────────────────────────────────────
# Painel Supabase → Settings → API

# URL do projeto (público — usado no frontend e backend)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_ID.supabase.co

# Anon key (público — apenas leitura dos dados disponíveis)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXX

# Service Role key (SECRETO — nunca expor no frontend!)
# Usada apenas nas API routes do admin para operações com permissão total
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# CHECKLIST antes do deploy:
#  [ ] JWT_SECRET com pelo menos 64 caracteres aleatórios
#  [ ] ADMIN_PASSWORD_HASH gerado com bcrypt (não use texto puro!)
#  [ ] SUPABASE_SERVICE_ROLE_KEY preenchida e NUNCA enviada ao Git
#  [ ] Bucket "imoveis" criado no Supabase Storage como Public Bucket
#  [ ] Tabela "properties" criada no Supabase com as colunas corretas
# ─────────────────────────────────────────────────────────────────────────────
